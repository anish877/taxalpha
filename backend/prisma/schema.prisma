generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BrokerKind {
  SELF
  EXTERNAL
}

enum FormSource {
  SEED
  UPLOAD
}

enum FormStatus {
  DRAFT
  NEEDS_REVIEW
  PUBLISHED
}

enum ClientBrokerRole {
  PRIMARY
  ADDITIONAL
}

enum ClientSetupStatus {
  INCOMPLETE
  ACTIVE
}

enum InvestorProfileOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum StatementOfFinancialConditionOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum BrokerageAlternativeInvestmentOrderDisclosureOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum BrokerageAccreditedInvestorVerificationOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brokers           Broker[]
  clients           Client[]
  uploadedPdfFills  ClientUploadedPdfFill[]
  uploadedDocuments ClientDocument[]
}

model Broker {
  id          String     @id @default(cuid())
  ownerUserId String
  name        String
  email       String
  kind        BrokerKind
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  clientLinks ClientBroker[]

  @@unique([ownerUserId, email])
}

model Client {
  id          String   @id @default(cuid())
  ownerUserId String
  name        String
  email       String
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  setupStatus ClientSetupStatus @default(ACTIVE)

  owner                                   User                                                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  brokerLinks                             ClientBroker[]
  formSelections                          ClientFormSelection[]
  formPdfs                                ClientFormPdf[]
  investorProfileOnboarding               InvestorProfileOnboarding?
  statementOfFinancialConditionOnboarding StatementOfFinancialConditionOnboarding?
  baiodfOnboarding                        BrokerageAlternativeInvestmentOrderDisclosureOnboarding?
  investmentBaiodfOnboardings             InvestmentBaiodfOnboarding[]
  baiv506cOnboarding                      BrokerageAccreditedInvestorVerificationOnboarding?
  dynamicForms                            DynamicFormResponse[]
  clientProfileValues                     ClientProfileValue[]
  uploadedPdfFills                        ClientUploadedPdfFill[]
  documents                               ClientDocument[]
  investments                             ClientInvestment[]
  isPreview                               Boolean                                                  @default(false)

  @@unique([ownerUserId, email])
}

model ClientInvestment {
  id                    String   @id @default(cuid())
  clientId              String
  name                  String
  position              Int
  baiodfSyncRequestedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client            Client                                                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  baiodfOnboarding  InvestmentBaiodfOnboarding?
  agreementPdfFill  ClientUploadedPdfFill?                                    @relation("InvestmentAgreement")
  formPdfs          ClientFormPdf[]

  @@unique([clientId, position])
  @@index([clientId])
}

model ClientBroker {
  clientId String
  brokerId String
  role     ClientBrokerRole

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  broker Broker @relation(fields: [brokerId], references: [id], onDelete: Cascade)

  @@id([clientId, brokerId])
}

model FormCatalog {
  id             String     @id @default(cuid())
  code           String     @unique
  title          String     @unique
  active         Boolean    @default(true)
  source         FormSource @default(SEED)
  status         FormStatus @default(PUBLISHED)
  // AI-ingested forms: the generated FormSchema, the source PDF location, and
  // the count of fields the engine could not confidently map (for admin review).
  schema         Json?
  templateUrl    String?
  unmappedCount  Int?
  ingestionState Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  formSelections ClientFormSelection[]
}

model ClientFormSelection {
  clientId String
  formId   String

  client Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  form   FormCatalog @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@id([clientId, formId])
}

// Answers for AI-ingested (schema-driven) forms. Generic JSON keyed by question
// id — the dynamic counterpart to the bespoke per-form onboarding tables.
model DynamicFormResponse {
  id          String   @id @default(cuid())
  clientId    String
  formCode    String
  answers     Json     @default("{}") // KEPT for back-compat (legacy flat path)
  status      String   @default("IN_PROGRESS")
  stepData    Json     @default("{}") // { "1": {...}, "2": {...} } per-step fields
  stepCursors Json     @default("{}") // { "1": 3, "2": 0 } per-step question index
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, formCode])
}

// Canonical cross-form investor profile (spec Part 3.2). Read-only sink for
// uploaded forms; written only by gold-form projections with sourceRank.
model ClientProfileValue {
  id             String   @id @default(cuid())
  clientId       String
  canonicalField String
  value          Json
  sourceFormCode String
  sourceRank     Int      @default(0)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, canonicalField])
  @@index([clientId])
}

model ClientFormPdf {
  id                String    @id @default(cuid())
  clientId          String
  investmentId      String?
  formCode          String
  workspaceFormCode String
  pdfUrl            String
  documentTitle     String?
  fileName          String?
  sourceRunId       String?
  generatedAt       DateTime?
  receivedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())

  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  investment ClientInvestment? @relation(fields: [investmentId], references: [id], onDelete: SetNull)

  @@unique([clientId, formCode, pdfUrl])
  @@index([clientId, workspaceFormCode, receivedAt(sort: Desc)])
  @@index([investmentId, receivedAt(sort: Desc)])
  @@index([receivedAt(sort: Desc)])
}

model ClientUploadedPdfFill {
  id              String    @id @default(cuid())
  clientId        String
  investmentId    String?   @unique
  ownerUserId     String
  originalFileKey String?
  originalPdfUrl  String?
  fileName        String?
  pdfFingerprint  String?
  status          String    @default("DRAFT")
  analysisStartedAt DateTime?
  analysisRunId     String?
  analysisStage     String?
  analysisError     String?
  analysisAttempts  Int       @default(0)
  mappingLayout   Json?
  resolvedLayout  Json?
  valueOverrides  Json      @default("{}")
  warnings        Json      @default("[]")
  generatedPdfUrl String?
  generatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner      User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  investment ClientInvestment? @relation("InvestmentAgreement", fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([clientId, updatedAt(sort: Desc)])
  @@index([ownerUserId])
  @@index([pdfFingerprint])
}

model ClientDocument {
  id               String   @id @default(cuid())
  clientId         String
  uploadedByUserId String
  fileName         String
  contentType      String
  sizeBytes        Int
  storageKey       String   @unique
  storageProvider  String   @default("LOCAL")
  createdAt        DateTime @default(now())

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt(sort: Desc)])
  @@index([uploadedByUserId])
}

model InvestorProfileOnboarding {
  id                        String                          @id @default(cuid())
  clientId                  String                          @unique
  status                    InvestorProfileOnboardingStatus @default(NOT_STARTED)
  step1RrName               String?
  step1RrNo                 String?
  step1CustomerNames        String?
  step1AccountNo            String?
  step1AccountType          Json?
  step1CurrentQuestionIndex Int                             @default(0)
  step1Data                 Json?
  step2CurrentQuestionIndex Int                             @default(0)
  step2Data                 Json?
  step3CurrentQuestionIndex Int                             @default(0)
  step3Data                 Json?
  step4CurrentQuestionIndex Int                             @default(0)
  step4Data                 Json?
  step5CurrentQuestionIndex Int                             @default(0)
  step5Data                 Json?
  step6CurrentQuestionIndex Int                             @default(0)
  step6Data                 Json?
  step7CurrentQuestionIndex Int                             @default(0)
  step7Data                 Json?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model StatementOfFinancialConditionOnboarding {
  id                        String                                        @id @default(cuid())
  clientId                  String                                        @unique
  status                    StatementOfFinancialConditionOnboardingStatus @default(NOT_STARTED)
  step1CurrentQuestionIndex Int                                           @default(0)
  step1Data                 Json?
  step2CurrentQuestionIndex Int                                           @default(0)
  step2Data                 Json?
  createdAt                 DateTime                                      @default(now())
  updatedAt                 DateTime                                      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BrokerageAlternativeInvestmentOrderDisclosureOnboarding {
  id                        String                                                        @id @default(cuid())
  clientId                  String                                                        @unique
  status                    BrokerageAlternativeInvestmentOrderDisclosureOnboardingStatus @default(NOT_STARTED)
  step1CurrentQuestionIndex Int                                                           @default(0)
  step1Data                 Json?
  step2CurrentQuestionIndex Int                                                           @default(0)
  step2Data                 Json?
  step3CurrentQuestionIndex Int                                                           @default(0)
  step3Data                 Json?
  createdAt                 DateTime                                                      @default(now())
  updatedAt                 DateTime                                                      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model InvestmentBaiodfOnboarding {
  id                        String                                                        @id @default(cuid())
  clientId                  String
  investmentId              String                                                        @unique
  status                    BrokerageAlternativeInvestmentOrderDisclosureOnboardingStatus @default(NOT_STARTED)
  step1CurrentQuestionIndex Int                                                           @default(0)
  step1Data                 Json?
  step2CurrentQuestionIndex Int                                                           @default(0)
  step2Data                 Json?
  step3CurrentQuestionIndex Int                                                           @default(0)
  step3Data                 Json?
  createdAt                 DateTime                                                      @default(now())
  updatedAt                 DateTime                                                      @updatedAt

  client     Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  investment ClientInvestment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model BrokerageAccreditedInvestorVerificationOnboarding {
  id                        String                                                  @id @default(cuid())
  clientId                  String                                                  @unique
  status                    BrokerageAccreditedInvestorVerificationOnboardingStatus @default(NOT_STARTED)
  step1CurrentQuestionIndex Int                                                     @default(0)
  step1Data                 Json?
  step2CurrentQuestionIndex Int                                                     @default(0)
  step2Data                 Json?
  createdAt                 DateTime                                                @default(now())
  updatedAt                 DateTime                                                @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}
