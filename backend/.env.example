PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=replace_with_at_least_32_characters
JWT_EXPIRES_IN=7d
# n8n webhook URLs are hardcoded per form in src/config/env.ts and are no longer
# configurable via env (prevents misrouting a form's PDF to the wrong workflow).
N8N_WEBHOOK_TIMEOUT_MS=5000
N8N_CALLBACK_SECRET=replace_with_callback_secret

# Document uploads (AWS S3). Leave S3_BUCKET unset to disable uploads.
# AWS credentials come from the SDK default chain: set AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY here, or attach an IAM role to the host.
# The IAM principal needs s3:PutObject and s3:GetObject on the bucket, and the
# bucket needs a CORS rule allowing PUT/GET from FRONTEND_URL.
AWS_REGION=us-east-1
S3_BUCKET=gpt-alpha-905418209881
S3_UPLOAD_PREFIX=investor-profile/government-id
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Client document uploads (Cloudinary). When these are set, documents uploaded
# from a client workspace are stored as authenticated raw Cloudinary assets.
# Leave unset for local-disk development storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLIENT_DOCUMENT_FOLDER=taxalpha/client-documents

# AI PDF mapping / AI fill (OpenRouter, OpenAI-compatible).
# Leave OPENROUTER_API_KEY unset to disable AI mapping and re-analysis.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REASONING_EFFORT=high
